{
  "requires": {
    "bundle": "ai"
  },
  "run": [
    {
      "when": "{{!exists('app')}}",
      "method": "shell.run",
      "params": {
        "message": ["git clone https://github.com/gantasmo/theDAW app"]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": ["git submodule update --init --recursive"]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": [
          "conda install -y -c conda-forge ffmpeg"
        ]
      }
    },
    {
      "when": "{{platform === 'linux'}}",
      "method": "shell.run",
      "params": {
        "message": [
          "conda install -y -c conda-forge c-compiler cxx-compiler make pkg-config"
        ]
      }
    },
    {
      "when": "{{platform === 'darwin'}}",
      "method": "shell.run",
      "params": {
        "path": "app",
        "env": {
          "CFLAGS": "-Wno-incompatible-function-pointer-types"
        },
        "message": ["uv sync --group dev"]
      }
    },
    {
      "when": "{{platform !== 'darwin'}}",
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": ["uv sync --group dev"]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app/frontend",
        "message": ["npm install"]
      }
    },
    {
      "when": "{{!exists('app/vj')}}",
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": ["git clone https://github.com/gantasmo/VJ-9000 vj"]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app/vj",
        "message": ["npm install"]
      }
    },
    {
      "when": "{{platform === 'darwin' && !exists(path.resolve(os.homedir(), '.cache', 'huggingface', 'hub', 'models--stabilityai--stable-audio-3-small-music'))}}",
      "method": "shell.run",
      "params": {
        "path": "app",
        "env": { "HF_HOME": "{{path.resolve(os.homedir(), '.cache', 'huggingface')}}" },
        "message": [
          "uv run python -c \"import os,pathlib; from huggingface_hub import snapshot_download; snapshot_download('cocktailpeanut/stable-audio-3-small-music'); h=pathlib.Path(os.environ.get('HF_HOME') or os.path.expanduser('~/.cache/huggingface'))/'hub'; s=h/'models--cocktailpeanut--stable-audio-3-small-music'; d=h/'models--stabilityai--stable-audio-3-small-music'; (s.rename(d) if s.exists() and not d.exists() else None)\""
        ]
      }
    },
    {
      "when": "{{platform !== 'darwin' && !exists(path.resolve(os.homedir(), '.cache', 'huggingface', 'hub', 'models--stabilityai--stable-audio-3-medium'))}}",
      "method": "shell.run",
      "params": {
        "path": "app",
        "env": { "HF_HOME": "{{path.resolve(os.homedir(), '.cache', 'huggingface')}}" },
        "message": [
          "uv run python -c \"import os,pathlib; from huggingface_hub import snapshot_download; snapshot_download('cocktailpeanut/stable-audio-3-medium'); h=pathlib.Path(os.environ.get('HF_HOME') or os.path.expanduser('~/.cache/huggingface'))/'hub'; s=h/'models--cocktailpeanut--stable-audio-3-medium'; d=h/'models--stabilityai--stable-audio-3-medium'; (s.rename(d) if s.exists() and not d.exists() else None)\""
        ]
      }
    }
  ]
}
