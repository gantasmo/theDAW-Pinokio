{
  "requires": {
    "bundle": "ai"
  },
  "run": [
    {
      "when": "{{!exists('app')}}",
      "method": "shell.run",
      "params": {
        "message": [
          "git clone https://github.com/gantasmo/theDAW app"
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": [
          "git submodule update --init --recursive"
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": [
          "conda install -y -c conda-forge ffmpeg"
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "message": [
          "uv sync --group dev"
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app/frontend",
        "message": [
          "npm install"
        ]
      }
    }
  ]
}
