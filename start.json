{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "path": "app",
        "env": {
        },
        "message": [
          "uv run uvicorn backend.server:app --port 8600"
        ],
        "on": [
          {
            "event": "/Uvicorn running on /i",
            "done": true
          }
        ]
      }
    },
    {
      "method": "shell.run",
      "params": {
        "path": "app/frontend",
        "env": {},
        "message": [
          "npm run dev"
        ],
        "on": [
          {
            "event": "/http://[^\\s\\n\\r]+/",
            "done": true
          }
        ]
      }
    },
    {
      "when": "{{input && input.event && Array.isArray(input.event) && input.event.length > 0}}",
      "method": "local.set",
      "params": {
        "url": "{{input.event[0]}}"
      }
    }
  ]
}
